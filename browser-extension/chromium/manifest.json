{
  "manifest_version": 3,
  "name": "CareVance Browser Tracking",
  "version": "0.1.0",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "CareVance Browser Tracking"
  }
}
